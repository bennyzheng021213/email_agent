    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "# Email deduplication logic\nimport hashlib\nfrom datetime import datetime, timedelta\n\n# In-memory cache for processed emails (in production, use database)\nprocessed_emails = {}\n\n# Clean old entries (older than 24 hours)\ncurrent_time = datetime.now()\nprocessed_emails = {email_id: timestamp for email_id, timestamp in processed_emails.items() \n                   if current_time - timestamp < timedelta(hours=24)}\n\nfiltered_items = []\nfor item in _items:\n    email_data = item[\"json\"]\n    \n    # Create unique ID from email metadata\n    email_id = email_data.get(\"id\", \"\")\n    if not email_id:\n        # Fallback: create hash from subject + from + timestamp\n        email_hash = hashlib.md5(\n            f\"{email_data.get('subject', '')}{email_data.get('from', '')}{email_data.get('date', '')}\".encode()\n        ).hexdigest()\n        email_id = email_hash\n    \n    # Check if already processed\n    if email_id in processed_emails:\n        print(f\"Email {email_id} already processed, skipping\")\n        continue\n    \n    # Mark as processed\n    processed_emails[email_id] = current_time\n    email_data[\"emailId\"] = email_id\n    filtered_items.append(item)\n\nprint(f\"Processed {len(filtered_items)} new emails, skipped {len(_items) - len(filtered_items)} duplicates\")\nreturn filtered_items"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        -96
      ],
      "id": "d157f2fd-e983-4a3f-8ae0-1a1cd1d83cc8",
      "name": "Smart Deduplication"
