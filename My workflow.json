    {
      "parameters": {
        "language": "javascript",
        "jsCode": "// Fallback analysis when AI fails\nconst emailData = $input.first().json;\n\n// Simple rule-based analysis\nconst subject = (emailData.subject || '').toLowerCase();\nconst body = (emailData.body || '').toLowerCase();\n\n// Check for business keywords\nconst businessKeywords = [\n  'inquiry', 'enquiry', 'question', 'request',\n  'proposal', 'quote', 'quotation', 'estimate',\n  'meeting', 'appointment', 'consultation',\n  'project', 'collaboration', 'partnership'\n];\n\nlet isBusiness = false;\nfor (const keyword of businessKeywords) {\n  if (subject.includes(keyword) || body.includes(keyword)) {\n    isBusiness = true;\n    break;\n  }\n}\n\n// Simple fallback analysis\nconst fallbackAnalysis = {\n  is_business: isBusiness,\n  category: isBusiness ? 'general_inquiry' : 'non_business',\n  urgency: 'low',\n  summary: 'Email processed with fallback analysis',\n  suggested_action: isBusiness ? 'review_manually' : 'no_reply_needed',\n  confidence: 0.3,\n  reasoning: 'Fallback analysis due to AI service failure'\n};\n\nemailData.ai_analysis = fallbackAnalysis;\nemailData.fallback_used = true;\n\nreturn [{\n  json: emailData\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        -96
      ],
      "id": "fallback-analyzer",
      "name": "Fallback Analyzer"
    }
