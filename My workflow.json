          "values": [
            {
              "role": "system",
              "content": "You are a professional email analysis assistant, skilled at judging email types and urgency levels. Always respond with valid JSON."
            },
            {
              "role": "user",
              "content": "Please analyze the following email content to determine if it is a business inquiry email, and provide detailed analysis:\n\nSender: {{$json.from}}\nSubject: {{$json.subject}}\nContent:\n{{$json.body}}\n\nPlease provide analysis results in the following JSON format:\n{\n  \"is_business\": boolean,\n  \"category\": string (e.g., \"product inquiry\", \"technical support\", \"collaboration request\", \"general inquiry\"),\n  \"urgency\": string (\"high\"/\"medium\"/\"low\"),\n  \"summary\": string (50-100 words summary),\n  \"suggested_action\": string (\"reply_immediately\", \"reply_later\", \"forward_to_others\", \"no_reply_needed\"),\n  \"confidence\": float (0-1),\n  \"reasoning\": string (brief explanation of judgment reasons)\n}"
            }
          ]
        },
        "responseFormat": {
          "type": "json_object"
        },
        "options": {
