# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.modify

# Database Configuration
DATABASE_URL=sqlite:///email_agent.db

# WeChat Notification
WECHAT_WEBHOOK_URL=your_wechat_webhook_url_here

# Application Settings
APP_NAME=EmailAgent
LOG_LEVEL=INFO
CHECK_INTERVAL_SECONDS=15
MAX_EMAILS_PER_CHECK=10

# Email Filter Settings
BLACKLISTED_DOMAINS=no-reply,newsletter,marketing,notification
BLACKLISTED_SUBJECTS=unsubscribe,newsletter,promotion,advertisement
MIN_CONTENT_LENGTH=50
